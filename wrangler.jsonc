{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "senior-residences-dashboard",
  "compatibility_date": "2026-03-20",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "senior-residences-eu",
      "database_id": "local-dev-database"
    }
  ]
}